# Public base URLs used by the shared header. NEXT_PUBLIC_CONSOLE_URL is
# also the Better Auth client baseURL the web app reads the cross-origin
# session from (the console must list this web origin in
# BETTER_AUTH_TRUSTED_ORIGINS + set BETTER_AUTH_COOKIE_DOMAIN).
NEXT_PUBLIC_WEB_URL=https://bitrouter.ai
NEXT_PUBLIC_CONSOLE_URL=https://cloud.bitrouter.ai
